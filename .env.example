# Trackademy frontend — Supabase connection (baked into the build by Vite).
# Copy to `.env` for LOCAL dev only. In CI/CD these are supplied by the
# Jenkins pipeline as --build-arg, so `.env` is NOT committed.
#
# Self-hosted Supabase example:
VITE_SUPABASE_URL=http://trackademy.onqtrack.com
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-jwt
